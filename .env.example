# Database Configuration
DB_NAME=nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=postgres

# AI Service Keys (Required for NLP and Analysis)
# REQUIRED: set valid API keys before starting services
# Get your free Groq key at: https://console.groq.com
GROQ_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Security
# REQUIRED: random string for JWT signing
JWT_SECRET=

# Networking
# Use http://localhost:80 for Docker setup
CORS_ALLOWED_ORIGINS=http://localhost:80
FRONTEND_URL=http://localhost:80
SPRING_PROFILES_ACTIVE=dev
